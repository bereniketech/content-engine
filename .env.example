# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here  # ENCRYPT in Vercel

# =============================================================================
# AI Providers
# =============================================================================
AI_PROVIDER=anthropic           # 'anthropic' | 'openai'
ANTHROPIC_API_KEY=              # ENCRYPT in Vercel
OPENAI_API_KEY=                 # Optional fallback — ENCRYPT in Vercel

# =============================================================================
# Public app URL (used for auth/email redirects and internal Inngest calls)
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://content-engine-one-eta.vercel.app
NEXT_PUBLIC_APP_URL=https://content-engine-one-eta.vercel.app

# =============================================================================
# Image Generation (Google Gemini Imagen)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Platform OAuth — ALL must be Vercel Encrypted in production
# =============================================================================
X_OAUTH_TOKEN=                  # ENCRYPT
X_OAUTH_TOKEN_SECRET=           # ENCRYPT
X_CONSUMER_KEY=                 # ENCRYPT
X_CONSUMER_SECRET=              # ENCRYPT
LINKEDIN_CLIENT_ID=             # ENCRYPT
LINKEDIN_CLIENT_SECRET=         # ENCRYPT
INSTAGRAM_ACCESS_TOKEN=         # ENCRYPT
REDDIT_CLIENT_ID=               # ENCRYPT
REDDIT_CLIENT_SECRET=           # ENCRYPT
REDDIT_REFRESH_TOKEN=           # ENCRYPT
NEWSLETTER_API_KEY=             # ENCRYPT

# =============================================================================
# Observability
# =============================================================================
SENTRY_DSN=                     # Sentry project DSN — ENCRYPT in Vercel
LOG_LEVEL=info                  # trace | debug | info | warn | error

# =============================================================================
# Inngest (Task 005)
# =============================================================================
INNGEST_EVENT_KEY=              # ENCRYPT
INNGEST_SIGNING_KEY=            # ENCRYPT
INNGEST_INTERNAL_SECRET=        # ENCRYPT — shared secret for Inngest→API route calls

# =============================================================================
# Upstash Redis (rate limiting)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=       # ENCRYPT

# =============================================================================
# E2E Testing
# =============================================================================
E2E_BASE_URL=http://localhost:3000
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=
