# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI Provider — set to "anthropic" or "openai" (auto-detects from whichever key is set)
AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Public app URL (used for auth/email redirects)
NEXT_PUBLIC_SITE_URL=https://content-engine-one-eta.vercel.app

# Image Generation (Google Gemini Imagen)
GEMINI_API_KEY=your_gemini_api_key_here
